    </div>

    <script>
        // Three.js Scene Setup
        let scene, camera, renderer;
        let cube, container, velocityArrow, gravityArrow;
        let isRunning = false;
        let isPaused = false;

        // Physics parameters
        const G = 9.81;
        const DRAG_COEFFICIENT = 0.47;
        const AIR_DENSITY = 1.225;
        const CUBE_MASS = 1.0;
        const CUBE_SIZE = 0.5;
        const CONTAINER_SIZE = 10.0;
        const COEFFICIENT_OF_RESTITUTION = 0.75;
        const DT = 0.016;

        // Simulation state
        let position = new THREE.Vector3(0, 5, 0);
        let velocity = new THREE.Vector3(2, 0, 1.5);
        let acceleration = new THREE.Vector3(0, 0, 0);
        let forces = {
            gravity: new THREE.Vector3(0, -CUBE_MASS * G, 0),
            drag: new THREE.Vector3(0, 0, 0),
            collision: new THREE.Vector3(0, 0, 0)
        };
        let energy = { kinetic: 0, potential: 0, total: 0 };

        function initThreeJS() {
            const container = document.getElementById('canvas');
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0xf0f4ff);

            camera = new THREE.PerspectiveCamera(75, container.clientWidth / container.clientHeight, 0.1, 1000);
            camera.position.set(8, 6, 8);
            camera.lookAt(0, 0, 0);

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            container.appendChild(renderer.domElement);

            // Lighting
            const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
            scene.add(ambientLight);
            const directionalLight = new THREE.DirectionalLight(0xffffff, 0.8);
            directionalLight.position.set(5, 10, 5);
            scene.add(directionalLight);

            // Container (wireframe box)
            const containerGeometry = new THREE.BoxGeometry(CONTAINER_SIZE, CONTAINER_SIZE, CONTAINER_SIZE);
            const containerMaterial = new THREE.MeshBasicMaterial({ 
                color: 0x888888, 
                wireframe: true,
                linewidth: 2
            });
            container = new THREE.Mesh(containerGeometry, containerMaterial);
            scene.add(container);

            // Cube
            const cubeGeometry = new THREE.BoxGeometry(CUBE_SIZE, CUBE_SIZE, CUBE_SIZE);
            const cubeMaterial = new THREE.MeshPhongMaterial({ color: 0x00ff00 });
            cube = new THREE.Mesh(cubeGeometry, cubeMaterial);
            cube.position.copy(position);
            scene.add(cube);

            // Arrows for force visualization
            gravityArrow = new THREE.ArrowHelper(
                new THREE.Vector3(0, -1, 0).normalize(),
                cube.position.clone(),
                2,
                0xff0000,
                0.5,
                0.3
            );
            scene.add(gravityArrow);

            velocityArrow = new THREE.ArrowHelper(
                velocity.clone().normalize(),
                cube.position.clone(),
                2,
                0x0088ff,
                0.5,
                0.3
            );
            scene.add(velocityArrow);

            window.addEventListener('resize', onWindowResize);
        }

        function onWindowResize() {
            const canvas = document.getElementById('canvas');
            const width = canvas.clientWidth;
            const height = canvas.clientHeight;
            camera.aspect = width / height;
            camera.updateProjectionMatrix();
            renderer.setSize(width, height);
        }

        function calculateDragForce() {
            const speed = velocity.length();
            if (speed < 0.01) {
                forces.drag.set(0, 0, 0);
                return;
            }
            const area = CUBE_SIZE * CUBE_SIZE;
            const dragMagnitude = 0.5 * AIR_DENSITY * speed * speed * DRAG_COEFFICIENT * area;
            forces.drag.copy(velocity).normalize().multiplyScalar(-dragMagnitude);
        }

        function checkCollisions() {
            forces.collision.set(0, 0, 0);
            const halfContainer = CONTAINER_SIZE / 2;
            const halfCube = CUBE_SIZE / 2;

            const axes = [0, 1, 2];
            for (let axis of axes) {
                if (position.getComponent(axis) - halfCube <= -halfContainer) {
                    const penetration = (-halfContainer) - (position.getComponent(axis) - halfCube);
                    const forceComponent = penetration * 100000;
                    forces.collision.setComponent(axis, forceComponent);
                    if (velocity.getComponent(axis) < 0) {
                        velocity.setComponent(axis, velocity.getComponent(axis) * -COEFFICIENT_OF_RESTITUTION * 0.9);
                    }
                    position.setComponent(axis, -halfContainer + halfCube + 0.01);
                }
                if (position.getComponent(axis) + halfCube >= halfContainer) {
                    const penetration = (position.getComponent(axis) + halfCube) - halfContainer;
                    const forceComponent = -penetration * 100000;
                    forces.collision.setComponent(axis, forceComponent);
                    if (velocity.getComponent(axis) > 0) {
                        velocity.setComponent(axis, velocity.getComponent(axis) * -COEFFICIENT_OF_RESTITUTION * 0.9);
                    }
                    position.setComponent(axis, halfContainer - halfCube - 0.01);
                }
            }
        }

        function calculateForces() {
            forces.gravity.set(0, -CUBE_MASS * G, 0);
            calculateDragForce();
            checkCollisions();
        }

        function updateEnergy() {
            const speed = velocity.length();
            energy.kinetic = 0.5 * CUBE_MASS * speed * speed;
            const height = position.y + CONTAINER_SIZE / 2;
            energy.potential = CUBE_MASS * G * height;
            energy.total = energy.kinetic + energy.potential;
        }

        function step() {
            calculateForces();
            
            const oldAcceleration = acceleration.clone();
            const netForce = forces.gravity.clone().add(forces.drag).add(forces.collision);
            
            position.addScaledVector(velocity, DT).addScaledVector(oldAcceleration, 0.5 * DT * DT);
            
            calculateForces();
            acceleration.copy(netForce).divideScalar(CUBE_MASS);
            
            velocity.addScaledVector(oldAcceleration.add(acceleration), 0.5 * DT);
            
            updateEnergy();
        }

        function updateVisualization() {
            cube.position.copy(position);
            
            // Update arrows
            scene.remove(gravityArrow);
            scene.remove(velocityArrow);
            
            gravityArrow = new THREE.ArrowHelper(
                new THREE.Vector3(0, -1, 0),
                position.clone(),
                forces.gravity.length() / 50,
                0xff0000,
                0.5,
                0.3
            );
            scene.add(gravityArrow);
            
            if (velocity.length() > 0.1) {
                velocityArrow = new THREE.ArrowHelper(
                    velocity.clone().normalize(),
                    position.clone(),
                    velocity.length(),
                    0x0088ff,
                    0.5,
                    0.3
                );
                scene.add(velocityArrow);
            }

            // Update info panel
            document.getElementById('posX').textContent = position.x.toFixed(2);
            document.getElementById('posY').textContent = position.y.toFixed(2);
            document.getElementById('posZ').textContent = position.z.toFixed(2);
            
            const speed = velocity.length();
            document.getElementById('speed').textContent = speed.toFixed(2);
            document.getElementById('velX').textContent = velocity.x.toFixed(2);
            document.getElementById('velY').textContent = velocity.y.toFixed(2);
            
            document.getElementById('forceGrav').textContent = forces.gravity.length().toFixed(2);
            document.getElementById('forceDrag').textContent = forces.drag.length().toFixed(2);
            document.getElementById('forceCol').textContent = forces.collision.length().toFixed(2);
            
            document.getElementById('energyK').textContent = energy.kinetic.toFixed(2);
            document.getElementById('energyP').textContent = energy.potential.toFixed(2);
            document.getElementById('energyT').textContent = energy.total.toFixed(2);
        }

        function animate() {
            requestAnimationFrame(animate);

            if (isRunning && !isPaused) {
                const timeScale = parseFloat(document.getElementById('timeScaleSlider').value);
                for (let i = 0; i < timeScale; i++) {
                    step();
                }
            }

            updateVisualization();
            renderer.render(scene, camera);
        }

        // Event listeners
        document.getElementById('startBtn').addEventListener('click', () => {
            isRunning = true;
            isPaused = false;
            document.getElementById('startBtn').disabled = true;
            document.getElementById('pauseBtn').disabled = false;
        });

        document.getElementById('pauseBtn').addEventListener('click', () => {
            isPaused = !isPaused;
            document.getElementById('pauseBtn').textContent = isPaused ? '▶ Resume' : '⏸ Pause';
        });

        document.getElementById('resetBtn').addEventListener('click', () => {
            isRunning = false;
            isPaused = false;
            position.set(0, 5, 0);
            velocity.set(2, 0, 1.5);
            acceleration.set(0, 0, 0);
            updateVisualization();
            document.getElementById('startBtn').disabled = false;
            document.getElementById('pauseBtn').disabled = true;
            document.getElementById('pauseBtn').textContent = '⏸ Pause';
        });

        document.getElementById('speedSlider').addEventListener('input', (e) => {
            const value = parseFloat(e.target.value);
            document.getElementById('speedValue').textContent = value.toFixed(1);
            if (!isRunning) {
                velocity.set(value, 0, 1.5);
                updateVisualization();
            }
        });

        document.getElementById('timeScaleSlider').addEventListener('input', (e) => {
            document.getElementById('timeScaleValue').textContent = e.target.value;
        });

        // Initialize
        initThreeJS();
        updateEnergy();
        updateVisualization();
        animate();
    </script>
</body>
