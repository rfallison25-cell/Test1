                <div class="legend">
                    <div style="font-weight: bold; margin-bottom: 8px;">Legend:</div>
                    <div class="legend-item">
                        <div class="legend-color" style="background: #00ff00;"></div>
                        <span>Cube (Green)</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-color" style="background: #888;"></div>
